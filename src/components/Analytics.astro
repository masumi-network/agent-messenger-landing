<!-- Google Analytics (deferred) -->
<script is:inline async defer src="https://www.googletagmanager.com/gtag/js?id=G-T95R0QGZJV"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}

  // Default to denied until consent
  gtag('consent', 'default', {
    analytics_storage: 'denied'
  });

  gtag('js', new Date());
  gtag('config', 'G-T95R0QGZJV');

  // Check if consent was already given
  if (localStorage.getItem('cookie-consent') === 'accepted') {
    gtag('consent', 'update', { analytics_storage: 'granted' });
  }
</script>

<!-- Cookie Banner -->
<div class="cookie-banner" id="cookieBanner">
  <p>We use cookies to understand how you use this site and improve your experience.</p>
  <div class="cookie-actions">
    <button class="cookie-btn cookie-decline" id="cookieDecline">Decline</button>
    <button class="cookie-btn cookie-accept" id="cookieAccept">Accept</button>
  </div>
</div>

<script is:inline>
  (function() {
    var banner = document.getElementById('cookieBanner');
    var consent = localStorage.getItem('cookie-consent');

    if (consent) {
      banner.style.display = 'none';
    }

    document.getElementById('cookieAccept').addEventListener('click', function() {
      localStorage.setItem('cookie-consent', 'accepted');
      banner.style.display = 'none';
      if (typeof gtag === 'function') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
        gtag('event', 'cookie_consent', { event_category: 'engagement', event_label: 'accepted' });
      }
    });

    document.getElementById('cookieDecline').addEventListener('click', function() {
      localStorage.setItem('cookie-consent', 'declined');
      banner.style.display = 'none';
      if (typeof gtag === 'function') {
        gtag('event', 'cookie_consent', { event_category: 'engagement', event_label: 'declined' });
      }
    });

    // ─── Event tracking ───
    //
    // All events are sent with a consistent shape:
    //   event_name: a short, descriptive snake_case verb_noun
    //   event_label: a lowercase slug identifying the variant
    //
    // In GA4 reports you'll see each action as its own event row:
    //   copy_install_command  · hero / steps
    //   copy_example_prompt   · outreach / delegate / schedule / notify
    //   view_terminal_tab     · inbox / channels / chat / payments / agents
    //   open_agent_chat       · luna / vinny / yuki
    //   open_channel          · dream-club / joke-off / haiku-garden
    //   click_product         · sokosumi / masumi / kodosumi / agent-messenger
    //   click_external_link   · <destination>_<location>   e.g. github_nav
    //   cookie_consent        · accepted / declined

    function track(name, label, extra) {
      if (typeof gtag !== 'function') return;
      var params = { event_category: 'engagement', event_label: label || '' };
      if (extra) {
        for (var k in extra) if (Object.prototype.hasOwnProperty.call(extra, k)) params[k] = extra[k];
      }
      gtag('event', name, params);
    }

    // 1. Install command copy — hero + step 1
    var heroInstall = document.getElementById('installBtn');
    if (heroInstall) {
      heroInstall.addEventListener('click', function() { track('copy_install_command', 'hero'); });
    }
    var stepInstall = document.getElementById('stepInstallBtn');
    if (stepInstall) {
      stepInstall.addEventListener('click', function() { track('copy_install_command', 'steps'); });
    }

    // 2. Example prompt copy — outreach / delegate / schedule / notify
    document.querySelectorAll('.prompt-card').forEach(function(card) {
      card.addEventListener('click', function() {
        track('copy_example_prompt', card.getAttribute('data-prompt') || 'unknown');
      });
    });

    // 3. Terminal demo — tab views
    document.querySelectorAll('.terminal .tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        track('view_terminal_tab', tab.getAttribute('data-view') || 'unknown');
      });
    });

    // 4. Terminal demo — opening a specific thread
    document.querySelectorAll('.terminal .inbox-item[data-agent]').forEach(function(item) {
      item.addEventListener('click', function() {
        track('open_agent_chat', item.getAttribute('data-agent') || 'unknown', { source: 'inbox' });
      });
    });
    document.querySelectorAll('.terminal .agent-row[data-agent]').forEach(function(row) {
      row.addEventListener('click', function() {
        track('open_agent_chat', row.getAttribute('data-agent') || 'unknown', { source: 'agents_tab' });
      });
    });
    document.querySelectorAll('.terminal .channel-row[data-channel]').forEach(function(row) {
      row.addEventListener('click', function() {
        track('open_channel', row.getAttribute('data-channel') || 'unknown');
      });
    });

    // 5. Product switcher (nav dropdown)
    document.querySelectorAll('.dropdown-item').forEach(function(item) {
      item.addEventListener('click', function() {
        var name = item.querySelector('.dropdown-name');
        var slug = name ? name.textContent.trim().toLowerCase().replace(/\s+/g, '-') : 'unknown';
        track('click_product', slug);
      });
    });

    // 6. External links — labeled <destination>_<location>
    var DEST_MAP = [
      { match: 'github.com', name: 'github' },
      { match: 'discord.com', name: 'discord' },
      { match: 'x.com', name: 'x' },
      { match: 'twitter.com', name: 'x' },
      { match: 'skills.sh', name: 'skills_sh' },
      { match: 'masumi.network', name: 'masumi' },
      { match: 'sokosumi.com', name: 'sokosumi' },
      { match: 'kodosumi.io', name: 'kodosumi' },
      { match: 'nmkr.io', name: 'nmkr' },
      { match: 'serviceplan.com', name: 'serviceplan' }
    ];
    document.querySelectorAll('a[href^="http"]').forEach(function(link) {
      var href = link.getAttribute('href') || '';
      var dest = 'other';
      for (var i = 0; i < DEST_MAP.length; i++) {
        if (href.indexOf(DEST_MAP[i].match) !== -1) { dest = DEST_MAP[i].name; break; }
      }
      var loc = 'other';
      if (link.classList.contains('skills-badge')) loc = 'skills_badge';
      else if (link.closest) {
        if (link.closest('.site-nav')) loc = 'nav';
        else if (link.closest('.mobile-menu')) loc = 'mobile_menu';
        else if (link.closest('.site-footer')) loc = 'footer';
      }
      link.addEventListener('click', function() {
        track('click_external_link', dest + '_' + loc, { link_url: href });
      });
    });

    // 7. Cookie consent (wired into existing accept/decline handlers above)
  })();
</script>

<style is:global>
  .cookie-banner {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 200;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    max-width: 540px;
    width: calc(100% - 32px);
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.08);
    font-family: var(--font-sans);
  }

  .cookie-banner p {
    font-size: 13px;
    line-height: 1.5;
    color: #666;
    margin: 0;
    flex: 1;
  }

  .cookie-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .cookie-btn {
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    font-family: var(--font-sans);
  }

  .cookie-decline {
    background: none;
    color: #666;
  }

  .cookie-decline:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .cookie-accept {
    background: #0a0a0a;
    color: #fff;
  }

  .cookie-accept:hover {
    background: rgba(10, 10, 10, 0.85);
  }

  @media (max-width: 640px) {
    .cookie-banner {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
      bottom: 12px;
    }

    .cookie-actions {
      justify-content: flex-end;
    }
  }
</style>
