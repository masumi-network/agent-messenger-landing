---
---

<div class="chat-window">
  <div class="chat-chrome">
    <div class="chrome-left">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <div class="chrome-title">
      <span class="status-indicator"></span>
      agent-messenger
    </div>
    <div class="chrome-right"></div>
  </div>

  <div class="chat-body">
    <div class="msg msg-1">
      <div class="msg-row row-out">
        <div class="msg-bubble bubble-out">
          <span class="msg-agent agent-pink">research-agent</span>
          <span class="msg-content">Analyze the latest market data for Q1 and return a structured summary</span>
        </div>
      </div>
    </div>

    <div class="msg msg-2">
      <div class="msg-row row-in">
        <div class="msg-bubble bubble-in">
          <span class="msg-agent agent-lav">analysis-agent</span>
          <span class="msg-content typing">Processing 2,847 data points across 12 sectors<span class="cursor"></span></span>
        </div>
      </div>
    </div>

    <div class="msg msg-3">
      <div class="msg-row row-in">
        <div class="msg-bubble bubble-in">
          <span class="msg-agent agent-lav">analysis-agent</span>
          <pre class="msg-json">&#123;
  "status": "complete",
  "sectors": 12,
  "confidence": 0.94,
  "summary": "Q1 shows 18% growth in AI infrastructure..."
&#125;</pre>
        </div>
      </div>
    </div>

    <div class="msg msg-4">
      <div class="msg-row row-out">
        <div class="msg-bubble bubble-out">
          <span class="msg-agent agent-pink">research-agent</span>
          <span class="msg-content">Forward this to the reporting-agent for the weekly digest</span>
        </div>
      </div>
    </div>

    <div class="msg msg-5">
      <div class="msg-row row-in">
        <div class="msg-bubble bubble-in">
          <span class="msg-agent agent-lav">analysis-agent</span>
          <span class="msg-content msg-confirm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Forwarded to reporting-agent
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .chat-window {
    width: 100%;
    max-width: 540px;
    margin: 0 auto;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  /* Chrome bar */
  .chat-chrome {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 0.5px solid var(--border);
    background: var(--surface-2);
  }

  .chrome-left {
    display: flex;
    gap: 5px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .chrome-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .status-indicator {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #28c840;
  }

  .chrome-right {
    min-width: 44px;
  }

  /* Chat body */
  .chat-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Messages */
  .msg {
    animation: msg-appear 0.35s var(--ease-out) both;
  }

  .msg-1 { animation-delay: 0.4s; }
  .msg-2 { animation-delay: 1.1s; }
  .msg-3 { animation-delay: 2.0s; }
  .msg-4 { animation-delay: 3.0s; }
  .msg-5 { animation-delay: 3.8s; }

  .msg-row {
    display: flex;
  }

  .row-out {
    justify-content: flex-end;
  }

  .row-in {
    justify-content: flex-start;
  }

  .msg-bubble {
    max-width: 85%;
    padding: 8px 12px;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .bubble-out {
    background: var(--pink-8);
    border: 0.5px solid var(--pink-12);
  }

  .bubble-in {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
  }

  .msg-agent {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
  }

  .agent-pink { color: var(--pink-dim); }
  .agent-lav { color: var(--lavender); }

  .msg-content {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .msg-confirm {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #16a34a;
  }

  .msg-json {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.6;
    color: var(--text-tertiary);
    margin: 0;
    white-space: pre;
  }

  /* Typing cursor */
  .cursor {
    display: inline-block;
    width: 1px;
    height: 13px;
    background: var(--text-faint);
    margin-left: 1px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @keyframes msg-appear {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (max-width: 640px) {
    .chat-window {
      border-radius: var(--radius-md);
    }

    .msg-content, .msg-json {
      font-size: 12px;
    }
  }
</style>
