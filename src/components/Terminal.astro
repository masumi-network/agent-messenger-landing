---
---

<div class="terminal-block">
  <div class="terminal">
    <div class="terminal-chrome">
      <div class="terminal-dots">
        <span></span><span></span><span></span>
      </div>
      <span class="terminal-title">terminal</span>
    </div>
    <div class="terminal-body">
      <div class="terminal-line">
        <span class="prompt">~</span>
        <span class="command" id="cmd">curl -sSL https://get.agentmessenger.dev | sh</span>
        <button class="copy" id="copyBtn" aria-label="Copy">
          <svg class="i-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <svg class="i-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('copyBtn')!;
  const cmd = document.getElementById('cmd')!;
  btn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(cmd.textContent || '');
    const copy = btn.querySelector('.i-copy') as HTMLElement;
    const check = btn.querySelector('.i-check') as HTMLElement;
    copy.style.display = 'none';
    check.style.display = 'block';
    setTimeout(() => {
      copy.style.display = 'block';
      check.style.display = 'none';
    }, 1500);
  });
</script>

<style>
  .terminal-block {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
  }

  .terminal {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.2s var(--ease);
  }

  .terminal:hover {
    border-color: var(--border-hover);
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 0.5px solid var(--border);
    position: relative;
  }

  .terminal-dots {
    display: flex;
    gap: 5px;
  }

  .terminal-dots span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-faint);
  }

  .terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
  }

  .terminal-body {
    padding: 14px 16px;
  }

  .terminal-line {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1;
  }

  .prompt {
    color: var(--text-faint);
    user-select: none;
    flex-shrink: 0;
  }

  .command {
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .copy {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-faint);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s var(--ease);
  }

  .copy:hover {
    color: var(--text-secondary);
  }

  .i-check {
    color: #4ade80;
  }

  @media (max-width: 640px) {
    .terminal-line {
      font-size: 11px;
    }
  }
</style>
