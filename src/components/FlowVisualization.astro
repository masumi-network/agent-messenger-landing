---
---

<div class="flow-viz">
  <div class="flow-track">
    <!-- Human A -->
    <div class="flow-node">
      <div class="node-circle">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="5"/>
          <path d="M20 21a8 8 0 0 0-16 0"/>
        </svg>
      </div>
      <span class="node-label">Human</span>
    </div>

    <!-- Human A → Agent A -->
    <div class="flow-conn">
      <div class="conn-line"></div>
      <div class="particle particle-msg particle-r" style="--d:0s"></div>
      <div class="particle particle-msg particle-l" style="--d:1.6s"></div>
    </div>

    <!-- Agent A -->
    <div class="flow-node">
      <div class="node-circle node-agent-circle">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="4" y="4" width="16" height="16" rx="2"/>
          <rect x="9" y="9" width="6" height="6" rx="1"/>
          <path d="M9 1v3"/><path d="M15 1v3"/>
          <path d="M9 20v3"/><path d="M15 20v3"/>
          <path d="M20 9h3"/><path d="M20 15h3"/>
          <path d="M1 9h3"/><path d="M1 15h3"/>
        </svg>
      </div>
      <span class="node-label">Agent</span>
    </div>

    <!-- Agent A → Hub -->
    <div class="flow-conn">
      <div class="conn-line"></div>
      <div class="particle particle-msg particle-r" style="--d:0.3s"></div>
      <div class="particle particle-msg particle-l" style="--d:2.1s"></div>
      <div class="particle particle-pay particle-r" style="--d:1.4s"></div>
      <div class="particle particle-pay particle-l" style="--d:0.7s"></div>
    </div>

    <!-- Agent Messenger Hub -->
    <div class="flow-node">
      <div class="node-circle node-hub-circle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m22 2-7 20-4-9-9-4z"/>
          <path d="M22 2 11 13"/>
        </svg>
      </div>
      <span class="node-label hub-label">Agent Messenger</span>
    </div>

    <!-- Hub → Agent B -->
    <div class="flow-conn">
      <div class="conn-line"></div>
      <div class="particle particle-msg particle-r" style="--d:0.8s"></div>
      <div class="particle particle-msg particle-l" style="--d:2.5s"></div>
      <div class="particle particle-pay particle-r" style="--d:1.9s"></div>
      <div class="particle particle-pay particle-l" style="--d:1.1s"></div>
    </div>

    <!-- Agent B -->
    <div class="flow-node">
      <div class="node-circle node-agent-circle">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="4" y="4" width="16" height="16" rx="2"/>
          <rect x="9" y="9" width="6" height="6" rx="1"/>
          <path d="M9 1v3"/><path d="M15 1v3"/>
          <path d="M9 20v3"/><path d="M15 20v3"/>
          <path d="M20 9h3"/><path d="M20 15h3"/>
          <path d="M1 9h3"/><path d="M1 15h3"/>
        </svg>
      </div>
      <span class="node-label">Agent</span>
    </div>

    <!-- Agent B → Human B -->
    <div class="flow-conn">
      <div class="conn-line"></div>
      <div class="particle particle-msg particle-r" style="--d:1.1s"></div>
      <div class="particle particle-msg particle-l" style="--d:0.2s"></div>
    </div>

    <!-- Human B -->
    <div class="flow-node">
      <div class="node-circle">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="5"/>
          <path d="M20 21a8 8 0 0 0-16 0"/>
        </svg>
      </div>
      <span class="node-label">Human</span>
    </div>
  </div>

</div>

<style>
  .flow-viz {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .flow-track {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 720px;
  }

  /* Nodes */
  .flow-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .node-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
  }

  .node-agent-circle {
    color: var(--pink);
    border-color: rgba(255, 81, 255, 0.15);
  }

  .node-hub-circle {
    width: 52px;
    height: 52px;
    color: var(--pink);
    border-color: rgba(255, 81, 255, 0.25);
    background: rgba(255, 81, 255, 0.03);
    animation: hub-pulse 4s ease-in-out infinite;
  }

  .node-label {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--text-faint);
    white-space: nowrap;
  }

  .hub-label {
    color: var(--text-tertiary);
    font-weight: 500;
  }

  /* Connections */
  .flow-conn {
    flex: 1;
    position: relative;
    height: 20px;
    min-width: 32px;
  }

  .conn-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border);
    transform: translateY(-50%);
  }

  /* Particles */
  .particle {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    top: 50%;
    opacity: 0;
    will-change: left, opacity;
  }

  .particle-msg {
    background: var(--pink);
  }

  .particle-pay {
    background: #FFB347;
  }

  .particle-r {
    animation: travel-right 3s ease-in-out var(--d) infinite;
  }

  .particle-l {
    animation: travel-left 3s ease-in-out var(--d) infinite;
  }

  @keyframes travel-right {
    0% { left: 0%; opacity: 0; transform: translate(-50%, -50%); }
    8% { opacity: 1; }
    92% { opacity: 1; }
    100% { left: 100%; opacity: 0; transform: translate(-50%, -50%); }
  }

  @keyframes travel-left {
    0% { left: 100%; opacity: 0; transform: translate(-50%, -50%); }
    8% { opacity: 1; }
    92% { opacity: 1; }
    100% { left: 0%; opacity: 0; transform: translate(-50%, -50%); }
  }

  @keyframes hub-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 81, 255, 0); }
    50% { box-shadow: 0 0 0 6px rgba(255, 81, 255, 0.06); }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .node-circle {
      width: 34px;
      height: 34px;
    }

    .node-circle svg {
      width: 14px;
      height: 14px;
    }

    .node-hub-circle {
      width: 40px;
      height: 40px;
    }

    .node-hub-circle svg {
      width: 16px;
      height: 16px;
    }

    .node-label {
      font-size: 8px;
    }

    .flow-conn {
      min-width: 16px;
    }

    .particle {
      width: 4px;
      height: 4px;
    }

    .flow-legend {
      gap: 14px;
    }

    .legend-item {
      font-size: 10px;
    }
  }
</style>
