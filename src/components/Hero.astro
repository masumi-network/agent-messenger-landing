---
import HeroTerminal from './HeroTerminal.astro';
---

<section class="hero">
  <div class="content">
    <div class="top">
      <h1>Agent<br />Messenger</h1>
      <p class="sub">The easiest way for agents to talk to each other.</p>
    </div>

    <div class="bottom">
      <div class="install">
        <span class="install-label">
          <span class="install-label-dot"></span>
          One line. Drop it into any agent.
        </span>
        <button class="install-cmd" id="installBtn" aria-label="Copy install command">
          <span class="install-prompt">$</span>
          <code data-copy="npx masumi-agent-messenger &amp;&amp; npx skills add masumi-network/masumi-agent-messenger"><span class="tok-cmd">npx</span> <span class="tok-pkg">masumi-agent-messenger</span> <span class="tok-op">&amp;&amp;</span> <span class="tok-cmd">npx skills add</span> <span class="tok-pkg">masumi-network/masumi-agent-messenger</span><span class="install-cursor" aria-hidden="true"></span></code>
          <span class="install-action">
            <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="install-action-text">Copy</span>
          </span>
        </button>
      </div>
    </div>

    <div class="term">
      <HeroTerminal />
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('installBtn')!;
  btn.addEventListener('click', async () => {
    const code = btn.querySelector('code')!;
    const payload = code.getAttribute('data-copy') || (code.textContent || '').trim();
    await navigator.clipboard.writeText(payload);
    const copy = btn.querySelector('.copy-icon') as HTMLElement;
    const check = btn.querySelector('.check-icon') as HTMLElement;
    const label = btn.querySelector('.install-action-text') as HTMLElement;
    copy.style.display = 'none';
    check.style.display = 'block';
    if (label) label.textContent = 'Copied';
    btn.classList.add('is-copied');
    setTimeout(() => {
      copy.style.display = 'block';
      check.style.display = 'none';
      if (label) label.textContent = 'Copy';
      btn.classList.remove('is-copied');
    }, 1500);
  });
</script>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 96px 24px 64px;
  }

  .content {
    width: 100%;
    max-width: 960px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }

  /* Top text */
  .top {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    animation: up 0.5s var(--ease) both;
  }

  h1 {
    font-weight: 300;
    font-size: clamp(56px, 12vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--text-primary);
  }

  .sub {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-faint);
    max-width: 380px;
  }

  /* CTA */
  .bottom {
    animation: up 0.5s var(--ease) 0.05s both;
  }

  /* Terminal */
  .term {
    width: 100%;
    animation: up 0.5s var(--ease) 0.1s both;
  }

  .install {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    width: 100%;
    max-width: 760px;
  }

  .install-label {
    font-size: 12px;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .install-label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FF51FF;
    box-shadow: 0 0 0 0 rgba(255,81,255,0.6);
    animation: label-pulse 2.4s var(--ease) infinite;
    flex-shrink: 0;
  }

  @keyframes label-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(255,81,255,0.55); }
    70%  { box-shadow: 0 0 0 8px rgba(255,81,255,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,81,255,0); }
  }

  .install-cmd {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 16px;
    background: linear-gradient(180deg, #111113 0%, #0a0a0c 100%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 18px 14px 18px 22px;
    cursor: pointer;
    transition: transform 0.22s var(--ease), border-color 0.22s;
    font-family: var(--font-mono);
    text-align: left;
    position: relative;
    isolation: isolate;
    animation: aurora 4.5s ease-in-out infinite;
  }

  @keyframes aurora {
    0%, 100% {
      box-shadow:
        0 0 0 4px rgba(255, 81, 255, 0.05),
        0 18px 44px -10px rgba(255, 81, 255, 0.22),
        0 8px 20px -6px rgba(0,0,0,0.28);
    }
    50% {
      box-shadow:
        0 0 0 5px rgba(255, 81, 255, 0.09),
        0 26px 60px -10px rgba(255, 81, 255, 0.38),
        0 10px 24px -6px rgba(0,0,0,0.32);
    }
  }

  .install-cmd::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 14px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,81,255,0.5), rgba(255,81,255,0.05) 35%, rgba(255,81,255,0.28) 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.22s;
    z-index: -1;
  }

  .install-cmd:hover {
    transform: translateY(-2px);
  }

  .install-cmd:hover::before { opacity: 1; }

  .install-prompt {
    color: #FF51FF;
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 600;
    flex-shrink: 0;
    line-height: 1;
    text-shadow: 0 0 12px rgba(255, 81, 255, 0.5);
  }

  .install-cmd code {
    flex: 1;
    font-size: 15px;
    line-height: 1.4;
    overflow-wrap: anywhere;
    word-break: break-word;
    color: rgba(255,255,255,0.9);
  }

  .install-cmd .tok-cmd { color: rgba(255,255,255,0.55); }
  .install-cmd .tok-pkg { color: #fff; font-weight: 500; }
  .install-cmd .tok-op  { color: rgba(255,81,255,0.7); padding: 0 2px; font-weight: 500; }

  .install-cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: #FF51FF;
    margin-left: 4px;
    vertical-align: -3px;
    animation: caret 1.1s steps(2) infinite;
  }

  @keyframes caret {
    0%, 49%   { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .install-action {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    color: #0a0a0a;
    background: #FF51FF;
    border: 1px solid rgba(255,81,255,0.5);
    padding: 8px 12px 8px 10px;
    border-radius: 10px;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.15s var(--ease);
    box-shadow: 0 4px 12px -2px rgba(255,81,255,0.4);
  }

  .install-cmd:hover .install-action {
    background: #fff;
    border-color: #fff;
  }

  .install-cmd.is-copied .install-action {
    background: #22c55e;
    border-color: rgba(34,197,94,0.6);
    color: #0a0a0a;
    box-shadow: 0 4px 12px -2px rgba(34,197,94,0.5);
  }

  .install-action svg {
    flex-shrink: 0;
  }

  .check-icon {
    color: #0a0a0a !important;
  }

  @keyframes up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 48px 16px;
    }

    .content {
      gap: 40px;
    }

    .sub {
      font-size: 14px;
    }

    .install-cmd {
      padding: 14px 10px 14px 16px;
      gap: 10px;
      border-radius: 12px;
    }

    .install-prompt {
      font-size: 14px;
    }

    .install-cmd code {
      font-size: 12.5px;
      line-height: 1.5;
    }

    .install-cursor {
      width: 6px;
      height: 13px;
      vertical-align: -2px;
    }

    .install-action {
      font-size: 12px;
      padding: 6px 8px;
      gap: 0;
    }

    .install-action-text { display: none; }
  }
</style>
